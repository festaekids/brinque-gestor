# Copie este arquivo para ".env" e preencha com seus dados do Supabase
# (Configurações > Chaves de API no painel do Supabase)

VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua-chave-publicavel-aqui

# Senha que você e seu colega vão usar para entrar no app
VITE_APP_PASSWORD=escolha-uma-senha
